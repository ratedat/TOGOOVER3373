{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RHODES OBS COMMANDER3373",
  "version": "0.1.0",
  "identifier": "com.ratedat.rhodes.obs.commander3373",
  "build": {
    "devUrl": "http://localhost:5173/control-v2",
    "frontendDist": "../app"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": [
      "resources/rhodes-app",
      "resources/bin"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
