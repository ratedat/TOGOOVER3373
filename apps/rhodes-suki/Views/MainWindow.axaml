<suki:SukiWindow
    x:Class="RhodesSuki.Views.MainWindow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:services="clr-namespace:RhodesSuki.Services"
    xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
    mc:Ignorable="d"
    Width="1500"
    Height="900"
    MinWidth="1180"
    MinHeight="720"
    Title="{Binding Title}">
  <suki:SukiWindow.Resources>
    <DataTemplate x:Key="PlainComboItemTemplate">
      <TextBlock Text="{Binding}" Foreground="#E8EFEF" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
    </DataTemplate>
    <DataTemplate x:Key="CampaignComboItemTemplate">
      <TextBlock Text="{Binding DisplayName}" Foreground="#E8EFEF" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
    </DataTemplate>
    <DataTemplate x:Key="ResourceProfileComboItemTemplate">
      <TextBlock Text="{Binding DisplayName}" Foreground="#E8EFEF" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
    </DataTemplate>
    <DataTemplate x:Key="AdbPresetComboItemTemplate">
      <StackPanel Spacing="2">
        <TextBlock Text="{Binding DisplayName}" Foreground="#E8EFEF" TextTrimming="CharacterEllipsis" />
        <TextBlock Text="{Binding PathSummary}" Foreground="#AAB6B8" FontSize="11" TextTrimming="CharacterEllipsis" />
      </StackPanel>
    </DataTemplate>
    <DataTemplate x:Key="AdbPresetSelectionTemplate">
      <TextBlock Text="{Binding DisplayName}" Foreground="#E8EFEF" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
    </DataTemplate>
    <DataTemplate x:Key="OcrEngineComboItemTemplate">
      <StackPanel Spacing="2">
        <TextBlock Text="{Binding Label}" Foreground="#E8EFEF" TextTrimming="CharacterEllipsis" />
        <TextBlock Text="{Binding Detail}" Foreground="#AAB6B8" FontSize="11" TextTrimming="CharacterEllipsis" />
      </StackPanel>
    </DataTemplate>
    <DataTemplate x:Key="OcrEngineSelectionTemplate">
      <TextBlock Text="{Binding Label}" Foreground="#E8EFEF" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
    </DataTemplate>
    <services:RhodesBitmapPathConverter x:Key="BitmapPathConverter" />
  </suki:SukiWindow.Resources>
  <suki:SukiWindow.Styles>
    <Style Selector="ComboBox">
      <Setter Property="Foreground" Value="#E8EFEF" />
      <Setter Property="Background" Value="#151D1E" />
      <Setter Property="BorderBrush" Value="#344143" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="8,5" />
      <Setter Property="MaxDropDownHeight" Value="360" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ComboBoxItem">
      <Setter Property="Foreground" Value="#E8EFEF" />
      <Setter Property="Background" Value="#101617" />
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ComboBoxItem:pointerover">
      <Setter Property="Background" Value="#1D2A2C" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="ComboBoxItem:selected">
      <Setter Property="Background" Value="#244145" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="ListBox.choicePane">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ListBox.choicePane ListBoxItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter
              Content="{TemplateBinding Content}"
              ContentTemplate="{TemplateBinding ContentTemplate}"
              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ListBox.choicePane ListBoxItem:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.choicePane ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Button.choiceCard">
      <Setter Property="Background" Value="#151D1E" />
      <Setter Property="BorderBrush" Value="#2B3638" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="9" />
      <Setter Property="Margin" Value="0,0,8,8" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="7"
              Padding="{TemplateBinding Padding}"
              MinHeight="{TemplateBinding MinHeight}">
            <ContentPresenter
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}"
                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.choiceCard:pointerover">
      <Setter Property="Background" Value="#1A2426" />
      <Setter Property="BorderBrush" Value="#3A5559" />
    </Style>
    <Style Selector="Button.choiceCard:pressed">
      <Setter Property="Background" Value="#203236" />
      <Setter Property="BorderBrush" Value="#4C6C72" />
    </Style>
  </suki:SukiWindow.Styles>
  <Grid RowDefinitions="Auto,*,Auto" Margin="18" RowSpacing="12">
    <Border CornerRadius="10" Padding="14" Background="#101617" BorderBrush="#2B3638" BorderThickness="1">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
        <StackPanel Spacing="2" MinWidth="245">
          <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" />
          <TextBlock Text="Suki / MAA 検証ワークベンチ" FontSize="12" Opacity="0.68" />
        </StackPanel>

        <StackPanel Grid.Column="1" Spacing="8">
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding CampaignHeaderTitle}" FontSize="16" FontWeight="SemiBold" />
              <TextBlock Text="{Binding CampaignHeaderDetail}" FontSize="12" Opacity="0.66" />
            </StackPanel>
            <ComboBox Grid.Column="2" Width="280" ItemsSource="{Binding Campaigns}" SelectedItem="{Binding SelectedCampaign, Mode=TwoWay}" ItemTemplate="{StaticResource CampaignComboItemTemplate}" SelectionBoxItemTemplate="{StaticResource CampaignComboItemTemplate}" />
          </Grid>

          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding HeaderStatusChips}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="8" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border CornerRadius="6" Padding="9,6" Background="#121A1B" BorderBrush="#2B3638" BorderThickness="1" MinWidth="86">
                    <StackPanel Spacing="1">
                      <TextBlock Text="{Binding Label}" FontSize="10" Opacity="0.62" />
                      <TextBlock Text="{Binding Value}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding Detail}" FontSize="9" Opacity="0.48" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </StackPanel>

        <StackPanel Grid.Column="2" Spacing="8" MinWidth="260">
          <Border CornerRadius="7" Padding="10,7" Background="#132021" BorderBrush="#2B4547" BorderThickness="1">
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding AdbHeaderTitle}" FontSize="13" FontWeight="SemiBold" />
              <TextBlock Text="{Binding AdbHeaderDetail}" FontSize="10" Opacity="0.66" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="保存" Command="{Binding SaveSettingsCommand}" />
            <Button Content="接続" Command="{Binding ConnectCommand}" />
            <Button Content="撮影" Command="{Binding CaptureCommand}" />
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="212,*,360" ColumnSpacing="12">
      <Border CornerRadius="10" Padding="10" Background="#101617" BorderBrush="#2B3638" BorderThickness="1">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
          <StackPanel Spacing="2">
            <TextBlock Text="WORKSPACE" FontSize="10" FontWeight="Bold" Opacity="0.45" />
            <TextBlock Text="{Binding WorkspaceTitle}" FontSize="16" FontWeight="SemiBold" />
          </StackPanel>

          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding WorkspaceNav}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Command="{Binding DataContext.SetWorkspaceCommand, ElementName=Root}" CommandParameter="{Binding Id}" Padding="10" Margin="0,0,0,7" HorizontalContentAlignment="Stretch">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8">
                      <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold" />
                      <TextBlock Grid.Column="1" Text="{Binding Subtitle}" FontSize="9" FontWeight="Bold" Opacity="0.52" VerticalAlignment="Center" />
                      <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Description}" FontSize="10" Opacity="0.58" TextWrapping="Wrap" />
                    </Grid>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Border Grid.Row="2" CornerRadius="8" Padding="10" Background="#121A1B" BorderBrush="#2B3638" BorderThickness="1">
            <TextBlock Text="新要素はレジストリとワークスペースへ追加し、トップレベルの操作を増やし過ぎない。" FontSize="10" TextWrapping="Wrap" Opacity="0.62" />
          </Border>
        </Grid>
      </Border>

      <Border Grid.Column="1" CornerRadius="10" Padding="14" Background="#111718" BorderBrush="#2B3638" BorderThickness="1">
        <Grid>
          <Grid RowDefinitions="Auto,*" RowSpacing="12" IsVisible="{Binding IsRunWorkspaceVisible}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="2">
                <TextBlock Text="ラン基本値" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="runStatusFull と IS固有値をここでレビューします。" FontSize="12" Opacity="0.62" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="API状態同期" Command="{Binding SyncRunStateFromApiCommand}" />
                <Button Content="基本値を認識" Command="{Binding OpenRecognitionProfileCommand}" CommandParameter="runStatusFull" />
              </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="14">
                <ItemsControl ItemsSource="{Binding RunFieldPreviews}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Width="224" MinHeight="112" CornerRadius="8" Padding="12" Margin="0,0,10,10" Background="#151D1E" BorderBrush="#2B3638" BorderThickness="1">
                        <StackPanel Spacing="5">
                          <TextBlock Text="{Binding Label}" FontSize="12" Opacity="0.64" />
                          <TextBlock Text="{Binding Value}" FontSize="24" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding Source}" FontSize="10" Opacity="0.58" />
                          <TextBlock Text="{Binding RecognitionTaskId}" FontFamily="Consolas" FontSize="10" Opacity="0.48" TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding Detail}" FontSize="10" Opacity="0.5" TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                  <Border CornerRadius="8" Padding="14" Background="#101617" BorderBrush="#2B3638" BorderThickness="1">
                    <StackPanel Spacing="8">
                      <TextBlock Text="IS固有値" FontSize="16" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding CampaignHeaderTitle}" FontSize="12" Opacity="0.66" />
                      <ItemsControl ItemsSource="{Binding SpecialValuePreviews}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Button Classes="choiceCard" Command="{Binding DataContext.OpenRecognitionProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding ProfileId}" HorizontalContentAlignment="Stretch">
                              <Border CornerRadius="7" Padding="10" Margin="0,0,0,8" Background="#151D1E" BorderBrush="#2B3638" BorderThickness="1">
                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="8" RowSpacing="2">
                                  <TextBlock Text="{Binding Label}" FontSize="13" FontWeight="SemiBold" />
                                  <TextBlock Grid.Column="1" Text="{Binding Kind}" FontSize="10" Opacity="0.58" />
                                  <TextBlock Grid.Row="1" Text="{Binding Value}" FontSize="18" FontWeight="SemiBold" />
                                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProfileId}" FontFamily="Consolas" FontSize="10" HorizontalAlignment="Right" Opacity="0.48" />
                                  <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding Detail}" FontSize="10" TextWrapping="Wrap" Opacity="0.58" />
                                </Grid>
                              </Border>
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="思案認識" Command="{Binding OpenRecognitionProfileCommand}" CommandParameter="is5ThoughtFull" />
                        <Button Content="認識へ移動" Command="{Binding SetWorkspaceCommand}" CommandParameter="recognition" />
                      </StackPanel>
                    </StackPanel>
                  </Border>

                  <Border Grid.Column="1" CornerRadius="8" Padding="14" Background="#101617" BorderBrush="#2B3638" BorderThickness="1">
                    <StackPanel Spacing="8">
                      <TextBlock Text="IS切替 / 現在のラン構成" FontSize="16" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding RunContextSummary}" FontSize="12" TextWrapping="Wrap" Opacity="0.72" />
                      <ItemsControl ItemsSource="{Binding CampaignPreviews}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border CornerRadius="7" Padding="10" Margin="0,0,0,8" Background="#151D1E" BorderBrush="#2B3638" BorderThickness="1">
                              <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                  <TextBlock Text="{Binding SelectedLabel}" FontSize="10" Opacity="0.58" />
                                  <TextBlock Text="{Binding CurrentRunLabel}" FontSize="10" Opacity="0.58" />
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{Binding Detail}" FontSize="10" TextWrapping="Wrap" Opacity="0.58" />
                                <Button Grid.Row="1" Grid.Column="1" Content="{Binding CurrentRunActionLabel}" Command="{Binding DataContext.SetCurrentCampaignCommand, ElementName=Root}" CommandParameter="{Binding}" IsEnabled="{Binding CanSetCurrentRun}" Padding="8,4" VerticalAlignment="Top" />
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="選択へ移動" Command="{Binding SetWorkspaceCommand}" CommandParameter="choices" />
                        <Button Content="出力へ移動" Command="{Binding SetWorkspaceCommand}" CommandParameter="output" />
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </Grid>
              </StackPanel>
            </ScrollViewer>
          </Grid>

          <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12" IsVisible="{Binding IsChoicesWorkspaceVisible}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="2">
                <TextBlock Text="選択カタログ" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="{Binding RunContextSummary}" FontSize="12" Opacity="0.62" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="オペレーター" Command="{Binding SetChoiceTabCommand}" CommandParameter="operators" />
                <Button Content="秘宝" Command="{Binding SetChoiceTabCommand}" CommandParameter="relics" />
                <Button Content="オペ認識" Command="{Binding OpenRecognitionProfileCommand}" CommandParameter="operatorsFull" />
                <Button Content="秘宝認識" Command="{Binding OpenRecognitionProfileCommand}" CommandParameter="relicsFull" />
                <Button Content="表示中の選択解除" Command="{Binding ClearVisibleChoicesCommand}" />
              </StackPanel>
            </Grid>

            <Border Grid.Row="1" CornerRadius="7" Padding="10,8" Background="#121A1B" BorderBrush="#2B3638" BorderThickness="1">
              <TextBlock Text="{Binding ChoicePanelTitle}" FontSize="13" FontWeight="SemiBold" />
            </Border>

            <Grid Grid.Row="2">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10" IsVisible="{Binding IsOperatorsPanelVisible}">
                <Grid ColumnDefinitions="*,110,145,145" ColumnSpacing="8">
                  <TextBox Text="{Binding OperatorSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="名前、職業、職分で検索" />
                  <ComboBox Grid.Column="1" ItemsSource="{Binding OperatorRarityOptions}" SelectedItem="{Binding OperatorRarityFilter, Mode=TwoWay}" ItemTemplate="{StaticResource PlainComboItemTemplate}" SelectionBoxItemTemplate="{StaticResource PlainComboItemTemplate}" />
                  <ComboBox Grid.Column="2" ItemsSource="{Binding OperatorClassOptions}" SelectedItem="{Binding OperatorClassFilter, Mode=TwoWay}" ItemTemplate="{StaticResource PlainComboItemTemplate}" SelectionBoxItemTemplate="{StaticResource PlainComboItemTemplate}" />
                  <ComboBox Grid.Column="3" ItemsSource="{Binding OperatorBranchOptions}" SelectedItem="{Binding OperatorBranchFilter, Mode=TwoWay}" ItemTemplate="{StaticResource PlainComboItemTemplate}" SelectionBoxItemTemplate="{StaticResource PlainComboItemTemplate}" />
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="*,Auto,76,Auto,Auto,Auto" ColumnSpacing="14">
                  <TextBlock Text="{Binding OperatorListSummary}" FontSize="12" VerticalAlignment="Center" Opacity="0.72" />
                  <TextBlock Grid.Column="1" Text="列" FontSize="12" VerticalAlignment="Center" Opacity="0.66" />
                  <ComboBox Grid.Column="2" ItemsSource="{Binding PaneColumnOptions}" SelectedItem="{Binding OperatorPaneColumns, Mode=TwoWay}" ItemTemplate="{StaticResource PlainComboItemTemplate}" SelectionBoxItemTemplate="{StaticResource PlainComboItemTemplate}" />
                  <CheckBox Grid.Column="3" Content="優先表示" IsChecked="{Binding OperatorShowSelectedFirst, Mode=TwoWay}" />
                  <CheckBox Grid.Column="4" Content="除外を隠す" IsChecked="{Binding OperatorHideExcluded, Mode=TwoWay}" />
                  <CheckBox Grid.Column="5" Content="選択のみ" IsChecked="{Binding OperatorSelectedOnly, Mode=TwoWay}" />
                </Grid>

                <ListBox Grid.Row="2" Classes="choicePane" ItemsSource="{Binding FilteredOperatorRows}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <ItemsControl ItemsSource="{Binding Items}" HorizontalAlignment="Stretch">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <UniformGrid Columns="{Binding Columns}" HorizontalAlignment="Stretch" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Button Classes="choiceCard" Command="{Binding DataContext.ToggleChoiceSelectedCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" MinHeight="70">
                              <Grid ColumnDefinitions="48,*" ColumnSpacing="8">
                                <Border Width="42" Height="42" CornerRadius="6" Background="#0C1011" BorderBrush="#2B3638" BorderThickness="1" VerticalAlignment="Top">
                                  <Image Source="{Binding ImagePath, Converter={StaticResource BitmapPathConverter}}" Stretch="UniformToFill" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                  <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                  <TextBlock Text="{Binding Heading}" FontSize="11" Opacity="0.72" TextTrimming="CharacterEllipsis" />
                                  <TextBlock Text="{Binding StateLabel}" FontSize="10" Opacity="0.72" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                              </Grid>
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>

              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10" IsVisible="{Binding IsRelicsPanelVisible}">
                <Grid ColumnDefinitions="*,260" ColumnSpacing="8">
                  <TextBox Text="{Binding RelicSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="秘宝名、番号、効果で検索" />
                  <ComboBox Grid.Column="1" ItemsSource="{Binding RelicCategoryOptions}" SelectedItem="{Binding RelicCategoryFilter, Mode=TwoWay}" ItemTemplate="{StaticResource PlainComboItemTemplate}" SelectionBoxItemTemplate="{StaticResource PlainComboItemTemplate}" />
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="*,Auto,76,Auto,Auto,Auto" ColumnSpacing="14">
                  <TextBlock Text="{Binding RelicListSummary}" FontSize="12" VerticalAlignment="Center" Opacity="0.72" />
                  <TextBlock Grid.Column="1" Text="列" FontSize="12" VerticalAlignment="Center" Opacity="0.66" />
                  <ComboBox Grid.Column="2" ItemsSource="{Binding PaneColumnOptions}" SelectedItem="{Binding RelicPaneColumns, Mode=TwoWay}" ItemTemplate="{StaticResource PlainComboItemTemplate}" SelectionBoxItemTemplate="{StaticResource PlainComboItemTemplate}" />
                  <CheckBox Grid.Column="3" Content="優先表示" IsChecked="{Binding RelicShowSelectedFirst, Mode=TwoWay}" />
                  <CheckBox Grid.Column="4" Content="除外を隠す" IsChecked="{Binding RelicHideExcluded, Mode=TwoWay}" />
                  <CheckBox Grid.Column="5" Content="選択のみ" IsChecked="{Binding RelicSelectedOnly, Mode=TwoWay}" />
                </Grid>

                <ListBox Grid.Row="2" Classes="choicePane" ItemsSource="{Binding FilteredRelicRows}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <ItemsControl ItemsSource="{Binding Items}" HorizontalAlignment="Stretch">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <UniformGrid Columns="{Binding Columns}" HorizontalAlignment="Stretch" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Button Classes="choiceCard" Command="{Binding DataContext.ToggleChoiceSelectedCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" MinHeight="118">
                              <Grid RowDefinitions="Auto,*" RowSpacing="7">
                                <Grid ColumnDefinitions="48,*" ColumnSpacing="8">
                                  <Border Width="42" Height="42" CornerRadius="6" Background="#0C1011" BorderBrush="#2B3638" BorderThickness="1" VerticalAlignment="Top">
                                    <Image Source="{Binding ImagePath, Converter={StaticResource BitmapPathConverter}}" Stretch="Uniform" />
                                  </Border>
                                  <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Heading}" FontSize="11" Opacity="0.72" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding StateLabel}" FontSize="10" Opacity="0.72" TextTrimming="CharacterEllipsis" />
                                  </StackPanel>
                                </Grid>
                                <TextBlock Grid.Row="1" Text="{Binding Detail}" FontSize="11" TextWrapping="Wrap" MaxLines="3" Opacity="0.58" />
                              </Grid>
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Grid>
          </Grid>

          <Grid RowDefinitions="Auto,Auto,Auto,160,*" RowSpacing="10" IsVisible="{Binding IsRecognitionWorkspaceVisible}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="2">
                <TextBlock Text="認識ワークフロー" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="MAA Resource task、候補化API、ローカルプレビューをここに集約します。" FontSize="12" Opacity="0.62" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="認識+反映" Command="{Binding RunSelectedProfileRecognitionAndApplyCommand}" />
                <Button Content="認識" Command="{Binding RunSelectedProfileRecognitionCommand}" />
                <Button Content="ADB API" Command="{Binding RunSelectedProfileAdbScanCommand}" />
                <Button Content="進捗" Command="{Binding RefreshRecognitionScanStatusCommand}" />
                <Button Content="履歴更新" Command="{Binding RefreshRecognitionScanHistoryCommand}" />
                <Button Content="全実行" Command="{Binding RunAllResourceTasksCommand}" />
                <Button Content="JSON保存" Command="{Binding ExportResourceTaskResultsCommand}" />
              </StackPanel>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="Auto,260,*,Auto" ColumnSpacing="10">
              <TextBlock Text="プロファイル" FontSize="12" VerticalAlignment="Center" Opacity="0.66" />
              <ComboBox Grid.Column="1" ItemsSource="{Binding ResourceProfiles}" SelectedItem="{Binding SelectedResourceProfile, Mode=TwoWay}" ItemTemplate="{StaticResource ResourceProfileComboItemTemplate}" SelectionBoxItemTemplate="{StaticResource ResourceProfileComboItemTemplate}" />
              <TextBox Grid.Column="2" Text="{Binding RhodesApiUrl, Mode=TwoWay}" />
              <Button Grid.Column="3" Content="候補化" Command="{Binding ConvertResourceTaskResultsCommand}" />
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10">
              <StackPanel Spacing="2">
                <TextBlock Text="プロファイル" FontSize="11" Opacity="0.58" />
                <TextBlock Text="{Binding SelectedResourceProfile.ProfileSummary}" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" Opacity="0.74" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock Text="API進捗" FontSize="11" Opacity="0.58" />
                <TextBlock Text="{Binding RecognitionScanStatus.Summary}" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" Opacity="0.74" />
              </StackPanel>
            </Grid>

            <Grid Grid.Row="3" RowDefinitions="Auto,*" RowSpacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="スキャン履歴" FontSize="13" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{Binding RecognitionScanHistory.Count}" FontFamily="Consolas" FontSize="12" Opacity="0.62" />
              </Grid>
              <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding RecognitionScanHistory}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border CornerRadius="7" Padding="8" Margin="0,0,0,6" Background="#101617" BorderBrush="#2B3638" BorderThickness="1">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10" RowSpacing="3">
                          <TextBlock Text="{Binding DisplayProfile}" FontSize="13" FontWeight="SemiBold" />
                          <TextBlock Grid.Column="1" Text="{Binding StatusLabel}" FontFamily="Consolas" FontSize="11" Opacity="0.72" />
                          <Button Grid.Column="2" Grid.RowSpan="3" Content="読込" Command="{Binding DataContext.LoadRecognitionScanHistoryCommand, ElementName=Root}" CommandParameter="{Binding}" Padding="8,3" VerticalAlignment="Center" />
                          <TextBlock Grid.Row="1" Text="{Binding Summary}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Opacity="0.66" />
                          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TimestampLabel}" FontFamily="Consolas" FontSize="11" Opacity="0.55" />
                          <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding Detail}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.48" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>

            <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding ResourceTasks}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border CornerRadius="7" Padding="10" Margin="0,0,0,8" Background="#151D1E" BorderBrush="#2B3638" BorderThickness="1">
                      <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="12" RowSpacing="5">
                        <StackPanel Spacing="2">
                          <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding Purpose}" FontSize="12" TextWrapping="Wrap" Opacity="0.66" />
                        </StackPanel>
                        <Button Grid.Column="1" Grid.RowSpan="3" Content="実行" Command="{Binding DataContext.RunResourceTaskCommand, ElementName=Root}" CommandParameter="{Binding}" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Entry}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Opacity="0.58" />
                        <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="*,*" ColumnSpacing="8">
                          <TextBlock Text="{Binding SourceSummary}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Opacity="0.56" />
                          <TextBlock Grid.Column="1" Text="{Binding ProfileSummary}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Opacity="0.56" />
                        </Grid>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>

          <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12" IsVisible="{Binding IsOutputWorkspaceVisible}">
            <StackPanel Spacing="2">
              <TextBlock Text="出力 / OBS" FontSize="20" FontWeight="SemiBold" />
              <TextBlock Text="サイドカーや大会向け表示で使う表示部品をここへ集約します。" FontSize="12" Opacity="0.62" />
            </StackPanel>

            <Border Grid.Row="1" CornerRadius="8" Padding="12" Background="#101617" BorderBrush="#2B3638" BorderThickness="1">
              <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto,120" RowSpacing="8" ColumnSpacing="10">
                <StackPanel Orientation="Horizontal" Spacing="14">
                  <CheckBox Content="別ウィンドウ" IsChecked="{Binding OutputSeparateWindow, Mode=TwoWay}" />
                  <CheckBox Content="大会向け" IsChecked="{Binding OutputTournamentMode, Mode=TwoWay}" />
                  <CheckBox Content="透過背景" IsChecked="{Binding OutputTransparentBackground, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                  <Button Content="Control" Command="{Binding OpenPreviewUrlCommand}" CommandParameter="/control-v2?screen=obs" />
                  <Button Content="Sidecar" Command="{Binding OpenPreviewUrlCommand}" CommandParameter="/sidecar" />
                  <Button Content="Overlay" Command="{Binding OpenPreviewUrlCommand}" CommandParameter="/overlay" />
                </StackPanel>
                <TextBox Grid.Column="2" Text="{Binding OutputScrollSpeed, Mode=TwoWay}" HorizontalContentAlignment="Right" />
                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="OBSプレビュー、ブラウザソース、サイドカー表示で共通の表示部品を管理します。" FontSize="11" TextWrapping="Wrap" Opacity="0.62" />
                <TextBlock Grid.Row="1" Grid.Column="2" Text="px/s" FontSize="11" HorizontalAlignment="Right" Opacity="0.58" />
              </Grid>
            </Border>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding OutputParts}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border CornerRadius="8" Padding="12" Margin="0,0,0,10" Background="#151D1E" BorderBrush="#2B3638" BorderThickness="1">
                      <Grid ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="4">
                        <StackPanel Spacing="2">
                          <TextBlock Text="{Binding Label}" FontSize="15" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding BindingPath}" FontFamily="Consolas" FontSize="10" Opacity="0.48" />
                        </StackPanel>
                        <CheckBox Grid.Column="1" Content="表示" IsChecked="{Binding Enabled, Mode=TwoWay}" VerticalAlignment="Center" />
                        <CheckBox Grid.Column="2" Content="スクロール" IsChecked="{Binding ScrollEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                        <CheckBox Grid.Column="3" Content="除外反映" IsChecked="{Binding HideExcluded, Mode=TwoWay}" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="4" Text="{Binding Detail}" FontSize="11" TextWrapping="Wrap" Opacity="0.62" />
                        <TextBlock Grid.Row="2" Text="{Binding SizeLabel}" FontFamily="Consolas" FontSize="11" Opacity="0.6" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>

          <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="12" IsVisible="{Binding IsRuntimeWorkspaceVisible}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="2">
                <TextBlock Text="ランタイム" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="MAA ADB接続 · ADB · MAA · GLM-OCR · Ollama · Hyper-V" FontSize="12" Opacity="0.62" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="端末一覧" Command="{Binding RefreshAdbDevicesCommand}" />
                <Button Content="APIテスト" Command="{Binding RunAdbApiTestCommand}" />
                <Button Content="状態確認" Command="{Binding RefreshOptionalRuntimesCommand}" />
                <Button Content="接続" Command="{Binding ConnectCommand}" />
                <Button Content="撮影" Command="{Binding CaptureCommand}" />
              </StackPanel>
            </Grid>

            <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="92,*,Auto" RowSpacing="8" ColumnSpacing="8">
              <TextBlock Text="プリセット" FontSize="12" VerticalAlignment="Center" Opacity="0.66" />
              <ComboBox Grid.Column="1" ItemsSource="{Binding AdbPresets}" SelectedItem="{Binding SelectedAdbPreset, Mode=TwoWay}" ItemTemplate="{StaticResource AdbPresetComboItemTemplate}" SelectionBoxItemTemplate="{StaticResource AdbPresetSelectionTemplate}" />
              <Button Grid.Column="2" Content="適用" Command="{Binding ApplyAdbPresetCommand}" CommandParameter="{Binding SelectedAdbPreset}" />

              <TextBlock Grid.Row="1" Text="ADB" FontSize="12" VerticalAlignment="Center" Opacity="0.66" />
              <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding AdbPath, Mode=TwoWay}" />

              <TextBlock Grid.Row="2" Text="接続先" FontSize="12" VerticalAlignment="Center" Opacity="0.66" />
              <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding AdbSerial, Mode=TwoWay}" PlaceholderText="127.0.0.1:6520 / 127.0.0.1:16384 / emulator-5554" />

              <TextBlock Grid.Row="3" Text="Config" FontSize="12" VerticalAlignment="Center" Opacity="0.66" />
              <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding AdbConfigJson, Mode=TwoWay}" />

              <TextBlock Grid.Row="4" Text="OCR" FontSize="12" VerticalAlignment="Center" Opacity="0.66" />
              <ComboBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" ItemsSource="{Binding OcrEngineOptions}" SelectedItem="{Binding SelectedOcrEngine, Mode=TwoWay}" ItemTemplate="{StaticResource OcrEngineComboItemTemplate}" SelectionBoxItemTemplate="{StaticResource OcrEngineSelectionTemplate}" />
            </Grid>

            <ItemsControl Grid.Row="2" ItemsSource="{Binding RuntimeCapabilities}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Width="226" MinHeight="116" CornerRadius="8" Padding="10" Margin="0,0,10,10" Background="#151D1E" BorderBrush="#2B3638" BorderThickness="1">
                    <Grid RowDefinitions="Auto,Auto,*,Auto" ColumnDefinitions="*,Auto" RowSpacing="4" ColumnSpacing="8">
                      <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                      <TextBlock Grid.Column="1" Text="{Binding Tag}" FontSize="10" Opacity="0.58" />
                      <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding State}" FontSize="12" Opacity="0.78" />
                      <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding Detail}" FontSize="10" TextWrapping="Wrap" Opacity="0.58" />
                      <TextBlock Grid.Row="3" Text="{Binding PrimaryAction}" FontSize="10" Opacity="0.68" />
                      <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding InstallLabel}" FontSize="10" Opacity="0.46" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Grid.Row="3" CornerRadius="8" Padding="10" Background="#151D1E" BorderBrush="#2B3638" BorderThickness="1">
              <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                <TextBlock Text="任意OCR" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="GLM-OCR/Ollamaは必要な検証環境だけで導入します。" FontSize="11" TextWrapping="Wrap" Opacity="0.62" VerticalAlignment="Center" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                  <Button Content="GLM導入" Command="{Binding InstallGlmOcrCommand}" />
                  <Button Content="GLM削除" Command="{Binding UninstallGlmOcrCommand}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Spacing="6">
                  <Button Content="Ollama導入" Command="{Binding InstallOllamaCommand}" />
                  <Button Content="Ollama起動" Command="{Binding StartOllamaCommand}" />
                  <Button Content="Ollama削除" Command="{Binding UninstallOllamaCommand}" />
                </StackPanel>
              </Grid>
            </Border>

            <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="10">
                <TextBlock Text="検出端末" FontSize="14" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding AdbDevices}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border CornerRadius="7" Padding="10" Margin="0,0,0,8" Background="#151D1E" BorderBrush="#2B3638" BorderThickness="1">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                          <StackPanel Spacing="2">
                            <TextBlock Text="{Binding Serial}" FontFamily="Consolas" FontSize="12" />
                            <TextBlock Text="{Binding DisplayName}" FontSize="11" TextWrapping="Wrap" Opacity="0.62" />
                          </StackPanel>
                          <Button Grid.Column="1" Content="使用" Command="{Binding DataContext.ApplyAdbDeviceCommand, ElementName=Root}" CommandParameter="{Binding}" IsEnabled="{Binding IsUsable}" VerticalAlignment="Center" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
          </Grid>

          <Grid RowDefinitions="Auto,*" RowSpacing="12" IsVisible="{Binding IsDebugWorkspaceVisible}">
            <StackPanel Spacing="2">
              <TextBlock Text="デバッグ" FontSize="20" FontWeight="SemiBold" />
              <TextBlock Text="検証用ログ、スクリーンショット、Resource task結果を確認します。" FontSize="12" Opacity="0.62" />
            </StackPanel>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="12">
                <ItemsControl ItemsSource="{Binding DebugLogLines}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Opacity="0.68" Margin="0,0,0,4" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="移行メモ" FontSize="14" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding MigrationSteps}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}" FontSize="11" TextWrapping="Wrap" Opacity="0.62" Margin="0,0,0,5" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </Grid>
      </Border>

      <Grid Grid.Column="2" RowDefinitions="310,*" RowSpacing="12">
        <Border CornerRadius="10" Padding="14" Background="#101617" BorderBrush="#2B3638" BorderThickness="1">
          <Grid RowDefinitions="Auto,*,Auto,86" RowSpacing="10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBlock Text="インスペクタ" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Grid.Column="1" Text="{Binding ResourceTaskDiagnostics.Summary}" FontSize="12" VerticalAlignment="Center" Opacity="0.72" />
            </Grid>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding InspectorRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border CornerRadius="7" Padding="9" Margin="0,0,0,8" Background="#151D1E" BorderBrush="#2B3638" BorderThickness="1">
                      <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="100,*" ColumnSpacing="8">
                        <TextBlock Text="{Binding Label}" FontSize="11" Opacity="0.58" />
                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Detail}" FontSize="10" TextWrapping="Wrap" Opacity="0.52" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <TextBlock Grid.Row="2" Text="診断" FontSize="13" FontWeight="SemiBold" />
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding ResourceTaskDiagnostics.Lines}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,5" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>

        <Border Grid.Row="1" CornerRadius="10" Padding="14" Background="#101617" BorderBrush="#2B3638" BorderThickness="1">
          <Grid RowDefinitions="Auto,155,Auto,*,Auto,*" RowSpacing="10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBlock Text="プレビュー / 結果" FontSize="18" FontWeight="SemiBold" />
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{Binding CapturePixelSizeLabel}" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" Opacity="0.58" />
                <TextBlock Text="{Binding RoiProjectionLabel}" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" Opacity="0.58" />
                <CheckBox Content="ROI" IsChecked="{Binding ShowRoiOverlay, Mode=TwoWay}" VerticalAlignment="Center" />
                <Button Content="候補を反映" Command="{Binding ApplyCandidateResultsCommand}" Padding="8,4" />
                <TextBlock Text="{Binding LastCandidateApplySummary}" FontSize="12" VerticalAlignment="Center" Opacity="0.58" />
              </StackPanel>
            </Grid>

            <Border Grid.Row="1" CornerRadius="7" Padding="8" Background="#0C1011" BorderBrush="#2B3638" BorderThickness="1">
              <Viewbox Stretch="Uniform">
                <Canvas Width="1280" Height="720">
                  <Image Source="{Binding LastCaptureImage}" Width="1280" Height="720" Stretch="Fill" />
                  <ItemsControl ItemsSource="{Binding RoiPreviewRows}" IsVisible="{Binding ShowRoiOverlay}" IsHitTestVisible="False" Width="1280" Height="720">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Canvas Width="1280" Height="720" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Canvas.Left="{Binding X}"
                                Canvas.Top="{Binding Y}"
                                Width="{Binding Width}"
                                Height="{Binding Height}"
                                BorderBrush="#36E2B6"
                                BorderThickness="3"
                                Background="#2236E2B6">
                          <TextBlock Text="{Binding Source}" FontSize="16" Foreground="#F3FFFB" Background="#CC081011" Padding="4,1" />
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <ItemsControl ItemsSource="{Binding SelectedRoiPreviewRows}" IsVisible="{Binding ShowRoiOverlay}" IsHitTestVisible="False" Width="1280" Height="720">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Canvas Width="1280" Height="720" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Canvas.Left="{Binding X}"
                                Canvas.Top="{Binding Y}"
                                Width="{Binding Width}"
                                Height="{Binding Height}"
                                BorderBrush="#FFD447"
                                BorderThickness="5"
                                Background="#22FFD447">
                          <TextBlock Text="{Binding Source}" FontSize="18" Foreground="#111100" Background="#EEFFD447" Padding="5,2" />
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Canvas>
              </Viewbox>
            </Border>

            <TextBlock Grid.Row="2" Text="候補" FontSize="13" FontWeight="SemiBold" />
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding CandidateResults}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border CornerRadius="7" Padding="9" Margin="0,0,0,8" Background="#132021" BorderBrush="#2B4547" BorderThickness="1">
                      <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="90,*,100" ColumnSpacing="8">
                        <TextBlock Text="{Binding Kind}" FontSize="11" Opacity="0.72" />
                        <TextBlock Grid.Column="1" Text="{Binding Label}" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2" Text="{Binding Confidence}" FontFamily="Consolas" FontSize="11" HorizontalAlignment="Right" Opacity="0.65" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Value}" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding Identity}" FontSize="11" HorizontalAlignment="Right" Opacity="0.55" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding DebugDetail}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.50" />
                        <TextBlock Grid.Row="2" Text="{Binding RawText}" FontSize="10" TextWrapping="Wrap" Opacity="0.45" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <TextBlock Grid.Row="4" Text="詳細" FontSize="13" FontWeight="SemiBold" />
            <ScrollViewer Grid.Row="5" VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="8">
                <ListBox ItemsSource="{Binding RecognitionScanLogRows}" SelectedItem="{Binding SelectedRecognitionScanLogRow, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="0">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border CornerRadius="7" Padding="9" Background="#101617" BorderBrush="#2B3638" BorderThickness="1" Margin="0,0,0,8">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                          <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" />
                          <TextBlock Grid.Column="1" Text="{Binding At}" FontFamily="Consolas" FontSize="11" Opacity="0.58" />
                          <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Summary}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Opacity="0.66" />
                          <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding Path}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.44" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <ListBox ItemsSource="{Binding OcrDetailRows}" SelectedItem="{Binding SelectedOcrDetailRow, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="0">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border CornerRadius="7" Padding="9" Background="#132021" BorderBrush="#2B4547" BorderThickness="1" Margin="0,0,0,8">
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                          <TextBlock Text="{Binding Text}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" />
                          <TextBlock Grid.Column="1" Text="{Binding ScoreLabel}" FontFamily="Consolas" FontSize="11" Opacity="0.66" />
                          <TextBlock Grid.Row="1" Text="{Binding Entry}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.50" />
                          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Detail}" FontFamily="Consolas" FontSize="10" Opacity="0.50" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <Border CornerRadius="7" Padding="9" Background="#151913" BorderBrush="#3A4528" BorderThickness="1">
                  <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="3">
                    <TextBlock Text="{Binding SelectedRoiEditDraft.StatusLabel}" FontSize="13" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="{Binding SelectedRoiEditDraft.RoiJson}" FontFamily="Consolas" FontSize="11" Opacity="0.78" />
                    <Button Grid.Column="2" Content="適用確認" Command="{Binding PreviewSelectedRoiDraftApplyCommand}" Padding="8,3" />
                    <Button Grid.Column="3" Content="適用" Command="{Binding ApplySelectedRoiDraftCommand}" Padding="8,3" />
                    <Button Grid.Column="4" Content="書出し" Command="{Binding ExportSelectedRoiDraftCommand}" Padding="8,3" />
                    <TextBlock Grid.Row="1" Grid.ColumnSpan="5" Text="{Binding SelectedRoiEditDraft.Detail}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.58" />
                    <TextBlock Grid.Row="2" Grid.ColumnSpan="5" Text="{Binding RoiDraftApplyResult.Message}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.58" />
                    <TextBlock Grid.Row="3" Grid.ColumnSpan="5" Text="{Binding RoiDraftApplyResult.TargetSummary}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.66" />
                    <TextBlock Grid.Row="4" Grid.ColumnSpan="5" Text="{Binding RoiDraftApplyResult.DiffSummary}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.72" />
                    <TextBlock Grid.Row="5" Grid.ColumnSpan="5" Text="{Binding RoiDraftApplyResult.BackupSummary}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.50" />
                  </Grid>
                </Border>

                <Border CornerRadius="7" Padding="9" Background="#121A1C" BorderBrush="#2E4448" BorderThickness="1">
                  <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="3">
                    <TextBlock Text="表示中ROI一括" FontSize="13" FontWeight="SemiBold" />
                    <Button Grid.Column="1" Content="全選択" Command="{Binding IncludeAllRoiBatchDraftsCommand}" Padding="8,3" />
                    <Button Grid.Column="2" Content="全解除" Command="{Binding ExcludeAllRoiBatchDraftsCommand}" Padding="8,3" />
                    <Button Grid.Column="3" Content="全候補確認" Command="{Binding PreviewVisibleRoiDraftsApplyCommand}" Padding="8,3" />
                    <Button Grid.Column="4" Content="全候補適用" Command="{Binding ApplyVisibleRoiDraftsCommand}" Padding="8,3" />
                    <Button Grid.Column="5" Content="セッション保存" Command="{Binding ExportRoiAdjustmentSessionCommand}" Padding="8,3" />
                    <TextBlock Grid.Row="1" Grid.ColumnSpan="6" Text="{Binding RoiBatchApplyResult.Summary}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.66" />
                    <TextBlock Grid.Row="2" Grid.ColumnSpan="6" Text="{Binding RoiBatchApplyResult.BackupSummary}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.50" />
                    <ListBox Grid.Row="3" Grid.ColumnSpan="6" ItemsSource="{Binding RoiBatchDrafts}" MaxHeight="118" Background="Transparent" BorderThickness="0" Padding="0">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="0,4,0,0">
                            <CheckBox IsChecked="{Binding IsIncluded, Mode=TwoWay}" VerticalAlignment="Center" />
                            <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                              <TextBlock Text="{Binding Entry}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.76" />
                              <TextBlock Grid.Column="1" Text="{Binding StateLabel}" FontSize="10" Opacity="0.78" />
                              <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding RoiJson}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.52" />
                              <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding StateDetail}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.46" />
                            </Grid>
                          </Grid>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                    <ListBox Grid.Row="4" Grid.ColumnSpan="6" ItemsSource="{Binding RoiBatchApplyResult.Results}" MaxHeight="132" Background="Transparent" BorderThickness="0" Padding="0">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Grid RowDefinitions="Auto,Auto" Margin="0,4,0,0">
                            <TextBlock Text="{Binding TargetSummary}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.66" />
                            <TextBlock Grid.Row="1" Text="{Binding DiffSummary}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.78" />
                          </Grid>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </Grid>
                </Border>

                <Border CornerRadius="7" Padding="9" Background="#131719" BorderBrush="#334147" BorderThickness="1">
                  <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="10" RowSpacing="6">
                    <TextBlock Text="ROI調整セッション" FontSize="13" FontWeight="SemiBold" />
                    <Button Grid.Column="1" Content="更新" Command="{Binding RefreshRoiAdjustmentSessionsCommand}" Padding="8,3" />
                    <ListBox Grid.Row="1" Grid.ColumnSpan="2" ItemsSource="{Binding RoiAdjustmentSessions}" MaxHeight="132" Background="Transparent" BorderThickness="0" Padding="0">
                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,4,0,0">
                            <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <Button Grid.Column="1" Content="読込" Command="{Binding DataContext.LoadRoiAdjustmentSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Padding="8,2" />
                            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Detail}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.62" />
                            <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding SessionPath}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.42" />
                          </Grid>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </Grid>
                </Border>

                <Button Content="{Binding MaaResourceGenerationResult.Message}" Command="{Binding RegenerateMaaResourceCommand}" HorizontalContentAlignment="Left" Padding="9,6" />

                <ListBox ItemsSource="{Binding RoiPreviewRows}" SelectedItem="{Binding SelectedRoiPreviewRow, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="0">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border CornerRadius="7" Padding="9" Background="#171B22" BorderBrush="#354052" BorderThickness="1" Margin="0,0,0,8">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="10" RowSpacing="3">
                          <TextBlock Text="{Binding DisplayTitle}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" />
                          <TextBlock Grid.Column="1" Text="{Binding EditKindLabel}" FontSize="11" Opacity="0.78" />
                          <TextBlock Grid.Row="1" Text="{Binding BoundsLabel}" FontFamily="Consolas" FontSize="10" Opacity="0.58" />
                          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProjectedRoiJson}" FontFamily="Consolas" FontSize="10" Opacity="0.72" />
                          <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding Raw}" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap" Opacity="0.40" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <ListBox ItemsSource="{Binding ResourceTaskResults}" SelectedItem="{Binding SelectedResourceTaskResult, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="0">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border CornerRadius="7" Padding="9" Background="#151D1E" BorderBrush="#2B3638" BorderThickness="1" Margin="0,0,0,8">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                          <TextBlock Text="{Binding Entry}" FontSize="13" FontWeight="SemiBold" />
                          <TextBlock Grid.Column="1" Text="{Binding Status}" FontFamily="Consolas" FontSize="12" />
                          <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Detail}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Opacity="0.72" />
                          <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding RecognitionDetailJson}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Opacity="0.56" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <ItemsControl ItemsSource="{Binding ProbePayloads}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border CornerRadius="7" Padding="9" Background="#151D1E" BorderBrush="#2B3638" BorderThickness="1" Margin="0,0,0,8">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="10" RowSpacing="4">
                          <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                          <Button Grid.Column="1" Grid.RowSpan="3" Content="実行" Command="{Binding DataContext.RunProbeCommand, ElementName=Root}" CommandParameter="{Binding}" VerticalAlignment="Center" />
                          <TextBlock Grid.Row="1" Text="{Binding Purpose}" FontSize="11" TextWrapping="Wrap" Opacity="0.66" />
                          <TextBlock Grid.Row="2" Text="{Binding Payload}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Opacity="0.58" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding ProbeResults}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border CornerRadius="7" Padding="9" Background="#151D1E" BorderBrush="#2B3638" BorderThickness="1" Margin="0,0,0,8">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                          <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                          <TextBlock Grid.Column="1" Text="{Binding Status}" FontFamily="Consolas" FontSize="12" />
                          <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Detail}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Opacity="0.72" />
                          <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding RecognitionDetailJson}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Opacity="0.56" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </Border>
      </Grid>
    </Grid>

    <Border Grid.Row="2" CornerRadius="7" Padding="10,8" Background="#101617" BorderBrush="#2B3638" BorderThickness="1">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
        <TextBlock Text="{Binding StatusMessage}" FontSize="12" TextWrapping="Wrap" Opacity="0.8" />
        <TextBlock Grid.Column="1" Text="{Binding CaptureState}" FontSize="11" TextWrapping="Wrap" Opacity="0.58" />
      </Grid>
    </Border>
  </Grid>
</suki:SukiWindow>
